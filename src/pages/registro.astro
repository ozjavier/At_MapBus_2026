---
import BaseLayout from '../layouts/BaseLayout.astro';

if (Astro.locals.user) {
  return Astro.redirect('/perfil');
}
---

<BaseLayout title="Crear cuenta">
  <div class="max-w-sm mx-auto bg-white rounded-lg shadow-sm p-6">
    <h1 class="text-2xl font-bold mb-6">Crear cuenta</h1>

    <form id="register-form" class="flex flex-col gap-4">
      <div>
        <label class="block text-sm font-semibold mb-1" for="name">Nombre</label>
        <input
          id="name"
          name="name"
          type="text"
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-ar-cerulean"
        />
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1" for="email">Correo</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-ar-cerulean"
        />
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1" for="password">Contraseña</label>
        <input
          id="password"
          name="password"
          type="password"
          minlength="8"
          required
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-ar-cerulean"
        />
        <p class="text-xs text-ar-oxford-disabled mt-1">Mínimo 8 caracteres.</p>
      </div>

      <p id="register-error" class="text-ar-folly text-sm hidden"></p>
      <p id="register-success" class="text-ar-cerulean text-sm hidden"></p>

      <button
        type="submit"
        class="cursor-pointer bg-ar-cerulean text-white rounded-md py-2 font-semibold hover:bg-ar-cerulean-hover transition-colors"
      >
        Crear cuenta
      </button>
    </form>

    <p class="text-sm text-center mt-4">
      ¿Ya tienes cuenta? <a href="/login" class="text-ar-cerulean underline">Inicia sesión</a>
    </p>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement | null;
  const errorEl = document.getElementById('register-error');
  const successEl = document.getElementById('register-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl?.classList.add('hidden');
    successEl?.classList.add('hidden');

    const formData = new FormData(form);
    const body = {
      name: formData.get('name') || undefined,
      email: formData.get('email'),
      password: formData.get('password'),
    };

    const res = await fetch('/api/auth/register', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (res.ok) {
      if (successEl) {
        successEl.textContent = 'Cuenta creada. Ya puedes iniciar sesión.';
        successEl.classList.remove('hidden');
      }
      form.reset();
      return;
    }

    const data = await res.json().catch(() => ({}));
    if (errorEl) {
      errorEl.textContent = data.error || 'No se pudo crear la cuenta';
      errorEl.classList.remove('hidden');
    }
  });
</script>
