---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { requireRole } from '../../../lib/guards.js';
import { listArticles } from '../../../lib/articles.js';

const guardResponse = requireRole(Astro, 'ADMIN');
if (guardResponse) return guardResponse;

const articles = await listArticles({ limit: 50 });
---

<BaseLayout title="Blog">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold text-ar-oxford">Blog</h1>
      <p class="text-ar-oxford-disabled">Articulos para SEO y contenido de rutas</p>
    </div>
    <a href="/admin/blog/nuevo" class="px-4 py-2 bg-ar-cerulean text-white rounded-md hover:bg-ar-cerulean-hover font-semibold">
      + Nuevo articulo
    </a>
  </div>

  {articles.length === 0 ? (
    <p class="text-ar-oxford-disabled">Todavia no hay articulos.</p>
  ) : (
    <div class="bg-white rounded-lg shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-ar-oxford text-white">
          <tr>
            <th class="text-left px-4 py-3">Titulo</th>
            <th class="text-left px-4 py-3">Estado</th>
            <th class="text-left px-4 py-3">Publicado</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {articles.map((a) => (
            <tr class="border-b border-gray-100 last:border-0">
              <td class="px-4 py-3 font-semibold text-ar-oxford">{a.title}</td>
              <td class="px-4 py-3">
                <span class={`px-2 py-1 rounded-full text-xs font-semibold ${a.status === 'PUBLISHED' ? 'bg-ar-cerulean-disabled text-ar-cerulean' : 'bg-gray-100 text-gray-500'}`}>
                  {a.status === 'PUBLISHED' ? 'Publicado' : 'Borrador'}
                </span>
              </td>
              <td class="px-4 py-3 text-ar-oxford-disabled">
                {a.published_at ? new Date(a.published_at).toLocaleDateString('es-MX') : '—'}
              </td>
              <td class="px-4 py-3 text-right">
                <a href={`/admin/blog/${a.id}`} class="text-ar-cerulean hover:underline">Editar</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</BaseLayout>