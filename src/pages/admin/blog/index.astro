---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { listArticles, countArticles } from '../../../lib/articles.js';

const PAGE_SIZE = 9;
const page = Math.max(1, Number(Astro.url.searchParams.get('page') || 1));

const [articles, total] = await Promise.all([
  listArticles({ status: 'PUBLISHED', limit: PAGE_SIZE, offset: (page - 1) * PAGE_SIZE }),
  countArticles({ status: 'PUBLISHED' }),
]);

const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
const canonicalPath = page > 1 ? `/blog?page=${page}` : '/blog';
---

<BaseLayout
  title="Blog"
  description="Guías, novedades y consejos sobre las rutas de transporte público en Atlixco."
  canonicalPath={canonicalPath}
>
  <h1 class="text-3xl font-bold text-ar-oxford mb-1">Blog de Atlixbus</h1>
  <p class="text-ar-oxford-disabled mb-8">Guías y novedades sobre nuestras rutas</p>

  {articles.length === 0 ? (
    <p class="text-ar-oxford-disabled">Todavia no hay articulos publicados.</p>
  ) : (
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {articles.map((a) => (
        <a href={`/blog/${a.slug}`} class="block bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition-shadow">
          {a.cover_image_url && (
            <img src={a.cover_image_url} alt={a.title} class="w-full h-40 object-cover" loading="lazy" />
          )}
          <div class="p-4">
            <h2 class="font-semibold text-ar-oxford mb-1">{a.title}</h2>
            {a.excerpt && <p class="text-sm text-ar-oxford-disabled line-clamp-3">{a.excerpt}</p>}
            {a.published_at && (
              <p class="text-xs text-ar-oxford-disabled mt-2">
                {new Date(a.published_at).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
            )}
          </div>
        </a>
      ))}
    </div>
  )}

  {totalPages > 1 && (
    <nav class="flex justify-center gap-2 mt-10">
      {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
        
        <a  href={`/blog?page=${p}`}
          class={`px-3 py-1.5 rounded-md text-sm font-semibold ${p === page ? 'bg-ar-cerulean text-white' : 'bg-white text-ar-oxford hover:bg-ar-cerulean-disabled'}`}
        >
          {p}
        </a>
      ))}
    </nav>
  )}
</BaseLayout>