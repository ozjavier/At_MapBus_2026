---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { requireRole } from '../../../lib/guards.js';
import { getArticleById, getArticleRoutes } from '../../../lib/articles.js';
import { listGroups } from '../../../lib/routeGroups.js';

const guardResponse = requireRole(Astro, 'ADMIN');
if (guardResponse) return guardResponse;

const id = Astro.params.id as string;
const isNew = id === 'nuevo';

const article = isNew ? null : await getArticleById(id);
if (!isNew && !article) {
  return new Response('Articulo no encontrado', { status: 404 });
}

const relatedRoutes = isNew ? [] : await getArticleRoutes(id);
const relatedRouteIds = new Set(relatedRoutes.map((r) => r.id));
const allRouteGroups = await listGroups();

const initialContentJson = JSON.stringify(article?.content_html ?? '');
---

<BaseLayout title={isNew ? 'Nuevo articulo' : `Editar — ${article.title}`}>
  <a href="/admin/blog" class="text-sm text-ar-cerulean hover:underline">&larr; Todos los articulos</a>

  <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-sm p-6 mt-4">
    <h1 class="text-2xl font-bold text-ar-oxford mb-6">
      {isNew ? 'Nuevo articulo' : 'Editar articulo'}
    </h1>

    <form id="article-form" class="flex flex-col gap-4">
      <div>
        <label class="block text-sm font-semibold mb-1">Titulo</label>
        <input
          name="title"
          type="text"
          required
          value={article?.title ?? ''}
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-ar-cerulean"
        />
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Slug (opcional, se genera solo)</label>
        <input
          name="slug"
          type="text"
          value={article?.slug ?? ''}
          placeholder="se-genera-automaticamente"
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-ar-cerulean"
        />
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Resumen (aparece en el listado y como meta description por defecto)</label>
        <textarea
          name="excerpt"
          rows="2"
          maxlength="500"
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-ar-cerulean"
        >{article?.excerpt ?? ''}</textarea>
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Imagen de portada (URL)</label>
        <input
          name="coverImageUrl"
          type="text"
          value={article?.cover_image_url ?? ''}
          placeholder="/uploads/blog/xxx.jpg"
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-ar-cerulean"
        />
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Contenido</label>
        <div id="editor-root"></div>
      </div>

      <div>
        <label class="block text-sm font-semibold mb-2">Rutas relacionadas</label>
        <div class="flex flex-wrap gap-3">
          {allRouteGroups.map((rg) => (
            <label class="flex items-center gap-2 text-sm border border-gray-200 rounded-md px-3 py-1.5 cursor-pointer">
              <input
                type="checkbox"
                name="routeGroupIds"
                value={rg.id}
                checked={relatedRouteIds.has(rg.id)}
              />
              Ruta {rg.route_number} {rg.name ? `— ${rg.name}` : ''}
            </label>
          ))}
        </div>
      </div>

      <details class="border border-gray-200 rounded-md p-3">
        <summary class="text-sm font-semibold cursor-pointer">SEO avanzado (opcional)</summary>
        <div class="mt-3 flex flex-col gap-3">
          <div>
            <label class="block text-sm mb-1">Meta titulo</label>
            <input name="metaTitle" type="text" value={article?.meta_title ?? ''} class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2" />
          </div>
          <div>
            <label class="block text-sm mb-1">Meta descripcion</label>
            <textarea name="metaDescription" rows="2" maxlength="500" class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2">{article?.meta_description ?? ''}</textarea>
          </div>
          <div>
            <label class="block text-sm mb-1">Tags (separados por coma)</label>
            <input name="tags" type="text" value={article?.tags ?? ''} placeholder="atlixco,eventos,ruta-2" class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2" />
          </div>
        </div>
      </details>

      <div id="form-feedback" class="hidden text-sm"></div>

      <div class="flex gap-3 justify-end">
        <button type="submit" name="_status" value="DRAFT" class="px-4 py-2 rounded-md border border-ar-cerulean text-ar-cerulean font-semibold hover:bg-ar-cerulean-disabled">
          Guardar borrador
        </button>
        <button type="submit" name="_status" value="PUBLISHED" class="px-4 py-2 rounded-md bg-ar-cerulean text-white font-semibold hover:bg-ar-cerulean-hover">
          Publicar
        </button>
      </div>
    </form>
  </div>
</BaseLayout>

<script define:vars={{ isNew, articleId: article?.id ?? null }}>
  window.__ARTICLE_CONTEXT__ = { isNew, articleId };
</script>

<script data-initial={initialContentJson} id="editor-data"></script>

<script>
  import ArticleEditor from '../../../components/admin/ArticleEditor.js';

  const { isNew, articleId } = window.__ARTICLE_CONTEXT__;
  const initialContentHtml = JSON.parse(document.getElementById('editor-data').dataset.initial || '""');

  const editorRoot = document.getElementById('editor-root');
  const editor = new ArticleEditor(editorRoot, {
    initialContentHtml,
    onImageUpload: async (file) => {
      const fd = new FormData();
      fd.append('file', file);
      const res = await fetch('/api/uploads/image', { method: 'POST', body: fd });
      if (!res.ok) return null;
      const data = await res.json();
      return data.url;
    },
  });

  const form = document.getElementById('article-form');
  const feedbackEl = document.getElementById('form-feedback');
  let submittedStatus = 'DRAFT';

  form.querySelectorAll('button[name="_status"]').forEach((btn) => {
    btn.addEventListener('click', () => { submittedStatus = btn.value; });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    feedbackEl.classList.add('hidden');

    const data = new FormData(form);
    const routeGroupIds = data.getAll('routeGroupIds');

    const payload = {
      title: data.get('title'),
      slug: data.get('slug') || undefined,
      excerpt: data.get('excerpt') || undefined,
      contentHtml: editor.getHTML(),
      coverImageUrl: data.get('coverImageUrl') || undefined,
      tags: data.get('tags') || undefined,
      metaTitle: data.get('metaTitle') || undefined,
      metaDescription: data.get('metaDescription') || undefined,
      status: submittedStatus,
      routeGroupIds,
    };

    const url = isNew ? '/api/articles' : `/api/articles/${articleId}`;
    const method = isNew ? 'POST' : 'PUT';

    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (res.ok) {
      const result = await res.json();
      if (isNew) {
        window.location.href = `/admin/blog/${result.id}`;
      } else {
        feedbackEl.textContent = 'Guardado correctamente.';
        feedbackEl.classList.remove('hidden');
        feedbackEl.classList.add('text-green-600');
      }
    } else {
      const err = await res.json().catch(() => ({}));
      feedbackEl.textContent = err.error || 'No se pudo guardar';
      feedbackEl.classList.remove('hidden');
      feedbackEl.classList.add('text-ar-folly');
    }
  });
</script>