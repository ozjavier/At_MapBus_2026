---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { requireRole } from '../../../lib/guards.js';
import { getEventPageById, listEventPageRoutes } from '../../../lib/eventPages.js';
import { listGroups } from '../../../lib/routeGroups.js';

const guardResponse = requireRole(Astro, 'ADMIN');
if (guardResponse) return guardResponse;

const id = Astro.params.id as string;
const isNew = id === 'nuevo';

const event = isNew ? null : await getEventPageById(id);
if (!isNew && !event) {
  return new Response('Pagina no encontrada', { status: 404 });
}

const eventRoutes = isNew ? [] : await listEventPageRoutes(id);
const usedRouteIds = new Set(eventRoutes.map((r) => r.route_group_id));
const allRouteGroups = await listGroups();
const availableRouteGroups = allRouteGroups.filter((rg) => !usedRouteIds.has(rg.id));

const initialContentJson = JSON.stringify(event?.content_html ?? '');
---

<BaseLayout title={isNew ? 'Nuevo evento' : `Editar — ${event.title}`}>
  <a href="/admin/eventos" class="text-sm text-ar-cerulean hover:underline">&larr; Todos los eventos</a>

  <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-sm p-6 mt-4">
    <h1 class="text-2xl font-bold text-ar-oxford mb-6">
      {isNew ? 'Nuevo evento' : 'Editar evento'}
    </h1>

    <form id="event-form" class="flex flex-col gap-4">
      <div>
        <label class="block text-sm font-semibold mb-1">Titulo</label>
        <input name="title" type="text" required value={event?.title ?? ''}
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-ar-cerulean" />
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Slug (opcional)</label>
        <input name="slug" type="text" value={event?.slug ?? ''} placeholder="se-genera-automaticamente"
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-ar-cerulean" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold mb-1">Lugar</label>
          <input name="placeName" type="text" value={event?.place_name ?? ''} placeholder="Feria de Huamantla"
            class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1">Fecha del evento</label>
          <input name="eventDate" type="date" value={event?.event_date ?? ''}
            class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Direccion</label>
        <input name="address" type="text" value={event?.address ?? ''}
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold mb-1">Latitud</label>
          <input name="latitude" type="number" step="any" value={event?.latitude ?? ''}
            class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1">Longitud</label>
          <input name="longitude" type="number" step="any" value={event?.longitude ?? ''}
            class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Imagen de portada (URL)</label>
        <input name="coverImageUrl" type="text" value={event?.cover_image_url ?? ''} placeholder="/uploads/blog/xxx.jpg"
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2" />
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1">Descripcion del evento</label>
        <div id="editor-root"></div>
      </div>

      <details class="border border-gray-200 rounded-md p-3">
        <summary class="text-sm font-semibold cursor-pointer">SEO avanzado (opcional)</summary>
        <div class="mt-3 flex flex-col gap-3">
          <div>
            <label class="block text-sm mb-1">Meta titulo</label>
            <input name="metaTitle" type="text" value={event?.meta_title ?? ''} class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2" />
          </div>
          <div>
            <label class="block text-sm mb-1">Meta descripcion</label>
            <textarea name="metaDescription" rows="2" maxlength="500" class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2">{event?.meta_description ?? ''}</textarea>
          </div>
        </div>
      </details>

      <div id="form-feedback" class="hidden text-sm"></div>

      <div class="flex gap-3 justify-end">
        <button type="submit" name="_status" value="DRAFT" class="px-4 py-2 rounded-md border border-ar-cerulean text-ar-cerulean font-semibold hover:bg-ar-cerulean-disabled">
          Guardar borrador
        </button>
        <button type="submit" name="_status" value="PUBLISHED" class="px-4 py-2 rounded-md bg-ar-cerulean text-white font-semibold hover:bg-ar-cerulean-hover">
          Publicar
        </button>
      </div>
    </form>
  </div>

  {!isNew && (
    <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-sm p-6 mt-4">
      <h2 class="text-xl font-bold text-ar-oxford mb-1">Directorio de rutas</h2>
      <p class="text-ar-oxford-disabled text-sm mb-4">Como llegar a este lugar en transporte publico</p>

      <div id="routes-directory" class="flex flex-col gap-3 mb-6">
        {eventRoutes.map((r, i) => (
          <div class="border border-gray-200 rounded-md p-3 flex gap-3 items-start" data-route-item-id={r.id}>
            <div class="flex flex-col gap-1 pt-1">
              <button type="button" class="btn-move-up text-ar-oxford-disabled hover:text-ar-cerulean" title="Subir" disabled={i === 0}>▲</button>
              <button type="button" class="btn-move-down text-ar-oxford-disabled hover:text-ar-cerulean" title="Bajar" disabled={i === eventRoutes.length - 1}>▼</button>
            </div>
            <div class="flex-1">
              <p class="font-semibold text-ar-oxford text-sm">Ruta {r.route_number} {r.name ? `— ${r.name}` : ''}</p>
              <textarea
                class="route-instructions w-full border border-ar-cerulean-disabled rounded-md px-2 py-1 text-sm mt-1"
                rows="2"
                placeholder="Ej. Bajate en la parada de la iglesia y camina 5 min"
              >{r.custom_instructions ?? ''}</textarea>
            </div>
            <button type="button" class="btn-remove-route text-ar-folly hover:text-ar-folly-hover text-sm font-semibold">Quitar</button>
          </div>
        ))}
      </div>

      <form id="add-route-form" class="flex gap-2 items-start">
        <select name="routeGroupId" required class="border border-ar-cerulean-disabled rounded-md px-3 py-2 text-sm">
          <option value="">Selecciona una ruta...</option>
          {availableRouteGroups.map((rg) => (
            <option value={rg.id}>Ruta {rg.route_number} {rg.name ? `— ${rg.name}` : ''}</option>
          ))}
        </select>
        <input name="customInstructions" type="text" placeholder="Instrucciones (opcional)"
          class="flex-1 border border-ar-cerulean-disabled rounded-md px-3 py-2 text-sm" />
        <button type="submit" class="px-4 py-2 bg-ar-cerulean text-white rounded-md hover:bg-ar-cerulean-hover font-semibold text-sm whitespace-nowrap">
          + Agregar
        </button>
      </form>
    </div>
  )}
</BaseLayout>

<script define:vars={{ isNew, eventId: event?.id ?? null }}>
  window.__EVENT_CONTEXT__ = { isNew, eventId };
</script>

<script data-initial={initialContentJson} id="editor-data"></script>

<script>
  import ArticleEditor from '../../../components/admin/ArticleEditor.js';

  const { isNew, eventId } = window.__EVENT_CONTEXT__;
  const initialContentHtml = JSON.parse(document.getElementById('editor-data').dataset.initial || '""');

  const editorRoot = document.getElementById('editor-root');
  const editor = new ArticleEditor(editorRoot, {
    initialContentHtml,
    onImageUpload: async (file) => {
      const fd = new FormData();
      fd.append('file', file);
      const res = await fetch('/api/uploads/image', { method: 'POST', body: fd });
      if (!res.ok) return null;
      const data = await res.json();
      return data.url;
    },
  });

  // --- Formulario principal (datos del evento) ---
  const form = document.getElementById('event-form');
  const feedbackEl = document.getElementById('form-feedback');
  let submittedStatus = 'DRAFT';

  form.querySelectorAll('button[name="_status"]').forEach((btn) => {
    btn.addEventListener('click', () => { submittedStatus = btn.value; });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    feedbackEl.classList.add('hidden');

    const data = new FormData(form);
    const payload = {
      title: data.get('title'),
      slug: data.get('slug') || undefined,
      placeName: data.get('placeName') || undefined,
      address: data.get('address') || undefined,
      latitude: data.get('latitude') ? Number(data.get('latitude')) : null,
      longitude: data.get('longitude') ? Number(data.get('longitude')) : null,
      contentHtml: editor.getHTML(),
      coverImageUrl: data.get('coverImageUrl') || undefined,
      eventDate: data.get('eventDate') || undefined,
      metaTitle: data.get('metaTitle') || undefined,
      metaDescription: data.get('metaDescription') || undefined,
      status: submittedStatus,
    };

    const url = isNew ? '/api/event-pages' : `/api/event-pages/${eventId}`;
    const method = isNew ? 'POST' : 'PUT';

    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (res.ok) {
      const result = await res.json();
      if (isNew) {
        window.location.href = `/admin/eventos/${result.id}`;
      } else {
        feedbackEl.textContent = 'Guardado correctamente.';
        feedbackEl.classList.remove('hidden');
        feedbackEl.classList.add('text-green-600');
      }
    } else {
      const err = await res.json().catch(() => ({}));
      feedbackEl.textContent = err.error || 'No se pudo guardar';
      feedbackEl.classList.remove('hidden');
      feedbackEl.classList.add('text-ar-folly');
    }
  });

  // --- Directorio de rutas (solo existe si el evento ya fue creado) ---
  if (!isNew) {
    const directoryEl = document.getElementById('routes-directory');
    const addRouteForm = document.getElementById('add-route-form');

    function currentItemIds() {
      return [...directoryEl.querySelectorAll('[data-route-item-id]')].map((el) => el.dataset.routeItemId);
    }

    async function persistOrder() {
      await fetch(`/api/event-pages/${eventId}/routes/reorder`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderedIds: currentItemIds() }),
      });
    }

    directoryEl.addEventListener('click', async (e) => {
      const itemEl = e.target.closest('[data-route-item-id]');
      if (!itemEl) return;
      const routeItemId = itemEl.dataset.routeItemId;

      if (e.target.matches('.btn-remove-route')) {
        if (!confirm('Quitar esta ruta del directorio?')) return;
        await fetch(`/api/event-pages/${eventId}/routes/${routeItemId}`, { method: 'DELETE' });
        itemEl.remove();
        return;
      }

      if (e.target.matches('.btn-move-up')) {
        const prev = itemEl.previousElementSibling;
        if (prev) directoryEl.insertBefore(itemEl, prev);
        await persistOrder();
        return;
      }

      if (e.target.matches('.btn-move-down')) {
        const next = itemEl.nextElementSibling;
        if (next) directoryEl.insertBefore(next, itemEl);
        await persistOrder();
        return;
      }
    });

    directoryEl.addEventListener('change', async (e) => {
      if (!e.target.matches('.route-instructions')) return;
      const itemEl = e.target.closest('[data-route-item-id]');
      const routeItemId = itemEl.dataset.routeItemId;
      const displayOrder = currentItemIds().indexOf(routeItemId);

      await fetch(`/api/event-pages/${eventId}/routes/${routeItemId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customInstructions: e.target.value, displayOrder }),
      });
    });

    addRouteForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(addRouteForm);
      const routeGroupId = data.get('routeGroupId');
      if (!routeGroupId) return;

      const res = await fetch(`/api/event-pages/${eventId}/routes`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          routeGroupId,
          customInstructions: data.get('customInstructions') || undefined,
        }),
      });

      if (res.ok) {
        window.location.reload(); // recarga simple: el select y el orden deben re-sincronizarse
      }
    });
  }
</script>