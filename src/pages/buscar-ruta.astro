---
import BaseLayout from '../layouts/BaseLayout.astro';
import { listActiveRoutesForFinder } from '../lib/publicRoutes.js';

const routes = await listActiveRoutesForFinder();
const routesJson = JSON.stringify(routes);
---

<BaseLayout title="Encontrar mi ruta">
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Panel de búsqueda -->
    <div class="lg:col-span-1 bg-white rounded-lg shadow-sm p-6 h-fit">
      <h1 class="text-2xl font-bold text-ar-oxford mb-1">Encontrar mi ruta</h1>
      <p class="text-sm text-ar-oxford-disabled mb-6">
        Escribe tu punto de partida y destino, o selecciónalos directamente
        en el mapa.
      </p>

      <div id="route-finder-root" data-routes={routesJson} class="space-y-4">
        <!-- Punto de partida -->
        <div class="space-y-2">
          <label class="block text-sm font-medium text-gray-700" for="start-input">
            Punto de partida
          </label>
          <div class="flex gap-2 relative">
            <input
              id="start-input"
              type="text"
              placeholder="Ej: C. 5 de Mayo 45"
              autocomplete="off"
              class="flex-1 w-full px-4 py-2 border border-ar-cerulean-disabled rounded-md focus:outline-none focus:ring-2 focus:ring-ar-cerulean"
            />
            <button
              type="button"
              id="start-pick-btn"
              title="Seleccionar en el mapa"
              class="cursor-pointer px-3 py-2 border border-gray-300 rounded-md bg-gray-100 hover:bg-gray-200 transition-all"
            >
              📍
            </button>
            <div
              id="start-suggestions"
              class="hidden absolute z-20 top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-md shadow-lg max-h-56 overflow-auto"
            >
            </div>
          </div>
          <button
            type="button"
            id="locate-btn"
            class="cursor-pointer text-xs text-ar-cerulean hover:underline"
          >
            Usar mi ubicación actual
          </button>
        </div>

        <!-- Destino -->
        <div class="space-y-2">
          <label class="block text-sm font-medium text-gray-700" for="end-input">
            Destino
          </label>
          <div class="flex gap-2 relative">
            <input
              id="end-input"
              type="text"
              placeholder="Ej: Zócalo de Atlixco"
              autocomplete="off"
              class="flex-1 w-full px-4 py-2 border border-ar-cerulean-disabled rounded-md focus:outline-none focus:ring-2 focus:ring-ar-cerulean"
            />
            <button
              type="button"
              id="end-pick-btn"
              title="Seleccionar en el mapa"
              class="cursor-pointer px-3 py-2 border border-gray-300 rounded-md bg-gray-100 hover:bg-gray-200 transition-all"
            >
              📍
            </button>
            <div
              id="end-suggestions"
              class="hidden absolute z-20 top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-md shadow-lg max-h-56 overflow-auto"
            >
            </div>
          </div>
        </div>

        <!-- Estado / errores -->
        <p id="finder-status" class="hidden text-sm"></p>

        <!-- Acciones -->
        <div class="space-y-2 pt-2">
          <button
            type="button"
            id="search-btn"
            disabled
            class="cursor-pointer disabled:cursor-auto w-full flex items-center justify-center gap-2 px-4 py-2 bg-ar-cerulean text-white rounded-md hover:bg-ar-cerulean-hover disabled:bg-ar-cerulean-disabled disabled:text-gray-500 transition-colors font-semibold"
          >
            Buscar rutas
          </button>
          <button
            type="button"
            id="clear-btn"
            class="cursor-pointer w-full px-4 py-2 bg-gray-200 rounded-md hover:bg-gray-300 transition-colors"
          >
            Limpiar búsqueda
          </button>
        </div>

        <!-- Resultados -->
        <div id="route-results" class="space-y-3 pt-2"></div>
      </div>
    </div>

    <!-- Mapa -->
    <div class="lg:col-span-3">
      <div
        id="finder-map"
        class="w-full h-[70vh] rounded-lg shadow-sm border border-ar-cerulean-disabled bg-gray-100"
        style="height: 70vh; min-height: 420px;"
      ></div>
      <p id="map-error" class="hidden text-xs text-ar-folly mt-1">
        No se pudo iniciar el mapa. Revisa la consola del navegador (F12).
      </p>
      <p class="text-xs text-gray-500 mt-2 flex items-center gap-1">
        <span class="inline-block w-3 h-3 rounded-full bg-ar-cerulean"></span> punto de abordaje
        <span class="inline-block w-3 h-3 rounded-full bg-ar-folly ml-3"></span> punto de bajada
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  import { RouteFinderApp } from '../lib/client/routeFinder.js';

  const root = document.getElementById('route-finder-root');
  const routes = JSON.parse(root.dataset.routes ?? '[]');

  const app = new RouteFinderApp({
    mapContainer: document.getElementById('finder-map'),
    routes,
    startInput: document.getElementById('start-input'),
    endInput: document.getElementById('end-input'),
    startSuggestions: document.getElementById('start-suggestions'),
    endSuggestions: document.getElementById('end-suggestions'),
    startPickBtn: document.getElementById('start-pick-btn'),
    endPickBtn: document.getElementById('end-pick-btn'),
    searchBtn: document.getElementById('search-btn'),
    clearBtn: document.getElementById('clear-btn'),
    locateBtn: document.getElementById('locate-btn'),
    resultsContainer: document.getElementById('route-results'),
    statusContainer: document.getElementById('finder-status'),
    mapErrorContainer: document.getElementById('map-error'),
  });

  // Referencia disponible en consola para depuración manual si hace falta.
  window.__routeFinderApp = app;
</script>