---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { listActiveRoutesForFinder } from '../../lib/publicRoutes.js';
import { getFavoriteRouteIdsForUser } from '../../lib/routeFavorites.js';

const routes = await listActiveRoutesForFinder();
const routesJson = JSON.stringify(routes);

const user = Astro.locals.user ?? null;
const isLoggedIn = !!user;
const favoriteIds = user ? await getFavoriteRouteIdsForUser(user.id) : [];
const favoriteIdsJson = JSON.stringify(favoriteIds);
---

<BaseLayout
  title="Mapa de rutas"
  description="Consulta todas las rutas de transporte público de Atlixco en un solo mapa, con paradas y sentido de recorrido, como el croquis del metro."
  canonicalPath="/ruta"
  fullBleed
  hideFooter
>
  <div class="relative flex flex-col lg:flex-row lg:h-[calc(100vh-4rem)]">
    <!-- Panel de listado -->
    <aside
      id="routes-panel"
      class="order-2 lg:order-1 relative z-10 flex flex-col bg-white lg:w-[380px] lg:h-full lg:overflow-y-auto lg:shadow-xl lg:border-r lg:border-gray-100"
    >
      <div class="p-5 sm:p-6 space-y-4">
        <div>
          <h1 class="text-xl sm:text-2xl font-bold text-ar-oxford">Mapa de rutas</h1>
          <p class="text-sm text-ar-oxford-disabled mt-1">
            Toca una ruta de la lista (o su línea en el mapa) para resaltar su
            recorrido. Vuelve a tocarla para quitar el resaltado.
          </p>
        </div>

        <!-- Leyenda -->
        <div class="bg-gray-50 border border-gray-100 rounded-lg p-3 space-y-2 text-xs text-ar-oxford-disabled">
          <p class="flex items-center gap-2.5">
            <span class="inline-block w-5 h-[3px] rounded-full bg-ar-cerulean shrink-0"></span>
            Recorrido de la ruta
          </p>
          <p class="flex items-center gap-2.5">
            <span class="inline-flex items-center justify-center shrink-0">
              <svg width="14" height="14" viewBox="0 0 14 14"><circle cx="7" cy="7" r="5" fill="#007991" stroke="white" stroke-width="2"/></svg>
            </span>
            Parada — puedes ascender o descender aquí
          </p>
          <p class="flex items-center gap-2.5">
            <span class="inline-flex items-center justify-center shrink-0">
              <svg width="16" height="16" viewBox="0 0 16 16"><circle cx="8" cy="8" r="6" fill="white" stroke="#007991" stroke-width="3"/></svg>
            </span>
            Inicio del recorrido (terminal)
          </p>
          <p class="flex items-center gap-2.5">
            <span class="inline-flex items-center justify-center shrink-0">
              <svg width="14" height="14" viewBox="0 0 24 24"><path d="M12 3 L19.5 19 L12 14.5 L4.5 19 Z" fill="#007991" stroke="white" stroke-width="1.4" stroke-linejoin="round"/></svg>
            </span>
            Sentido hacia donde avanza la ruta
          </p>
        </div>

        <div
          id="routes-overview-root"
          data-routes={routesJson}
          data-favorite-ids={favoriteIdsJson}
          data-logged-in={isLoggedIn ? 'true' : 'false'}
        >
          <div id="routes-list" class="space-y-2"></div>

          <p
            id="routes-empty"
            class="hidden text-sm text-ar-oxford-disabled text-center py-8"
          >
            Todavía no hay rutas publicadas.
          </p>
        </div>
      </div>
    </aside>

    <!-- Mapa -->
    <div class="order-1 lg:order-2 relative flex-1 lg:h-full">
      <div id="routes-map" class="w-full h-[42vh] lg:h-full bg-gray-100"></div>

      <p
        id="map-error"
        class="hidden absolute top-3 left-3 right-3 text-xs text-ar-folly bg-white px-3 py-2 rounded-md shadow"
      >
        No se pudo iniciar el mapa. Revisa la consola del navegador (F12).
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  import { RoutesOverviewMap } from '../../lib/client/routesOverviewMap.js';
  import { initFavoriteStars } from '../../lib/client/routeFavorites.js';

  const root = document.getElementById('routes-overview-root');
  const routes = JSON.parse(root?.dataset.routes ?? '[]');
  const favoriteIds = JSON.parse(root?.dataset.favoriteIds ?? '[]');
  const isLoggedIn = root?.dataset.loggedIn === 'true';

  initFavoriteStars({ isLoggedIn, loginRedirectPath: window.location.pathname });

  const app = new RoutesOverviewMap({
    mapContainer: document.getElementById('routes-map'),
    routes,
    listContainer: document.getElementById('routes-list'),
    mapErrorContainer: document.getElementById('map-error'),
    emptyStateContainer: document.getElementById('routes-empty'),
    favoriteIds,
  });

  // Referencia disponible en consola para depuración manual si hace falta.
  window.__routesOverviewApp = app;
</script>