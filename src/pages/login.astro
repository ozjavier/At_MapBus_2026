---
import BaseLayout from '../layouts/BaseLayout.astro';

// Si ya hay sesión activa, no tiene sentido mostrar el login.
if (Astro.locals.user) {
  return Astro.redirect('/perfil');
}
---

<BaseLayout title="Iniciar sesión">
  <div class="max-w-sm mx-auto bg-white rounded-lg shadow-sm p-6">
    <h1 class="text-2xl font-bold mb-6">Iniciar sesión</h1>

    <form id="login-form" class="flex flex-col gap-4">
      <div>
        <label class="block text-sm font-semibold mb-1" for="email">Correo</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-ar-cerulean"
        />
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1" for="password">Contraseña</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          class="w-full border border-ar-cerulean-disabled rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-ar-cerulean"
        />
      </div>

      <p id="login-error" class="text-ar-folly text-sm hidden"></p>

      <button
        type="submit"
        class="cursor-pointer bg-ar-cerulean text-white rounded-md py-2 font-semibold hover:bg-ar-cerulean-hover transition-colors"
      >
        Entrar
      </button>
    </form>

    <p class="text-sm text-center mt-3">
      <a href="/recuperar-password" class="text-ar-cerulean underline">¿Olvidaste tu contraseña?</a>
    </p>

    <p class="text-sm text-center mt-4">
      ¿No tienes cuenta? <a href="/registro" class="text-ar-cerulean underline">Regístrate</a>
    </p>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement | null;
  const errorEl = document.getElementById('login-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl?.classList.add('hidden');

    const formData = new FormData(form);
    const body = {
      email: formData.get('email'),
      password: formData.get('password'),
    };

    const res = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (res.ok) {
      window.location.href = '/perfil';
      return;
    }

    const data = await res.json().catch(() => ({}));
    if (errorEl) {
      errorEl.textContent = data.error || 'No se pudo iniciar sesión';
      errorEl.classList.remove('hidden');
    }
  });
</script>