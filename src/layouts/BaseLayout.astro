---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  noindex?: boolean;
  fullBleed?: boolean;
  hideFooter?: boolean;
}

const {
  title,
  description = 'Consulta rutas, horarios y tarifas de transporte publico en Atlixco.',
  image,
  canonicalPath,
  noindex = false,
  fullBleed = false,
  hideFooter = false,
} = Astro.props;

const user = Astro.locals.user ?? null;

import { SITE_NAME, SITE_URL } from '../lib/site.js';
const canonicalUrl = canonicalPath ? new URL(canonicalPath, SITE_URL).toString() : undefined;
const ogImage = image ? new URL(image, SITE_URL).toString() : undefined;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · {SITE_NAME}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-ar-oxford text-white">
      <div class="container mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="font-bold text-lg">Atlixbus</a>

        <nav class="flex items-center gap-6 text-sm font-semibold">
          <a href="/admin/rutas">Rutas</a>
          <a href="/blog">Blog</a>
          <a href="/eventos">Eventos</a>

          {user && <a href="/perfil">Perfil</a>}
          {user?.role === 'ADMIN' && <a href="/admin">Administración</a>}

          {user ? (
            <form method="POST" action="/api/auth/logout">
              <button type="submit" class="cursor-pointer px-3 py-1 bg-ar-folly rounded-md hover:bg-ar-folly-hover">
                Cerrar sesión
              </button>
            </form>
          ) : (
            <a href="/login" class="px-3 py-1 bg-ar-saffron text-ar-oxford rounded-md hover:bg-ar-cerulean hover:text-white transition-colors">
              Iniciar sesión
            </a>
          )}
        </nav>
      </div>
    </header>

    <main class={fullBleed ? 'flex-1' : 'flex-1 container mx-auto px-4 py-8'}>
      <slot />
    </main>

    {!hideFooter && (
      <footer class="text-center text-sm text-ar-oxford-disabled py-6">
        &copy; {new Date().getFullYear()} Atlixbus
      </footer>
    )}
  </body>
</html>